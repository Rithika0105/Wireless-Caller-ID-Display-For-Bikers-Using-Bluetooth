/**
* @brief  The application entry point.
*/
int main(void)
{
/* Reset of all peripherals, Initializes the Flash interface and the Systick. */
HAL_Init();
/* Configure the system clock */
SystemClock_Config();
/* Initialize all configured peripherals */
MX_GPIO_Init();
MX_SPI2_Init();
MX_USART1_UART_Init();
/* USER CODE BEGIN 2 */
// Initialize LCD
ST7735_Init();
ST7735_FillScreen(ST7735_RED);
HAL_Delay(1000);
ST7735_FillScreen(ST7735_GREEN);
ST7735_FillScreen(ST7735_BLACK);
// Initial Welcome Screen
ST7735_WriteString(5, 10, "SYSTEM READY", Font_7x10, ST7735_WHITE, ST7735_BLACK);
ST7735_WriteString(5, 25, "WAITING FOR BT...", Font_7x10, ST7735_BLUE, ST7735_BLACK);
// Start Bluetooth Interrupt Reception
HAL_UART_Receive_IT(&huart1, &temp_byte, 1);
/* USER CODE END 2 */
while (1)
 {
	 /* Inside your while(1) in main.c */
	if (msg_ready == 1)
	{
	    ST7735_FillScreen(ST7735_BLACK); // Wipe the old number
	    ST7735_WriteString(5, 10, "INCOMING:", Font_7x10, ST7735_WHITE, ST7735_BLACK);
	    // This will now show the FULL string: "9876543210 CALL IS COMING"
	    ST7735_WriteString(5, 40, rx_buffer, Font_7x10, ST7735_GREEN, ST7735_BLACK);
	    msg_ready = 0;
	}
 }
}
/* USER CODE BEGIN 4 */
/**
* @brief  UART Rx Transfer completed callback.
*/
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
   if (huart->Instance == USART1)
   {
       // ONLY trigger display when we see the Newline (\n) from the App
       if (temp_byte == '\n' || temp_byte == '\r')
       {
           rx_buffer[rx_index] = '\0'; // Null terminate the full string
           msg_ready = 1;              // Show "Number + Text" all at once
           rx_index = 0;               // Reset for next message
       }
       else
       {
           if (rx_index < sizeof(rx_buffer) - 1)
           {
               rx_buffer[rx_index++] = temp_byte;
           }
       }
       // Re-enable interrupt
       HAL_UART_Receive_IT(&huart1, &temp_byte, 1);
   }
}
